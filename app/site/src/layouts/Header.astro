---
/**
 * Header.astro
 * Site header with navigation
 *
 * Customize the navigation links and branding below
 */

const navLinks = [
  { href: '/#hero', label: 'Home' },
  { href: '/#services', label: 'Services' },
  { href: '/#about', label: 'About' },
  { href: '/#projects', label: 'projects' },
  { href: '/#contact', label: 'Contact' },
];
---

<section class="fixed top-0 left-0 right-0 z-50">
  <nav class="max-w-[90%] mx-auto lg:px-4 lg:pt-8 pt-4 px-4
   flex items-center justify-between">
    <!-- Logo / Brand -->
    <a
      href="/"
      class="lg:text-6xl text-4xl font-bold bg-gradient-to-l from-primary-light via-primary to-primary/90 bg-clip-text text-transparent"
    >
      <!-- Replace with your logo -->
      KAMICO
    </a>

    <!-- Desktop Navigation Links -->
    <ul class="hidden lg:flex gap-12 items-end bg-black/10 px-5 py-2 backdrop-blur-xs">
      {
        navLinks.map((link, index) => (
          <li class={`fade-in-up stagger-${index + 1}`}>
            <div class="hover:translate-x-1 duration-300">
              <a href={link.href} class="text-muted hover:text-primary-light duration-300 text-lg font-medium
              before:content-['▸'] before:absolute before:-left-4 before:opacity-0 hover:before:opacity-100 before:text-primary-light before:transition-opacity">
                {link.label}
              </a>
            </div>
          </li>
        ))
      }
    </ul>

    <!-- Mobile Menu Button -->
    <button id="hamburger-btn" class="md:hidden py-2" aria-label="Toggle menu">
      <i
        class="fas fa-bars text-xl bg-gradient-to-r from-primary-light via-primary-light/80 to-primary-light bg-clip-text text-transparent"
      ></i>
    </button>
  </nav>
</section>

<!-- Mobile Navigation Panel -->
<nav
  id="main-nav"
  class="fixed top-0 right-0 bottom-0 w-64 bg-black/70 backdrop-blur-md shadow-lg z-50 transform translate-x-full transition-transform duration-300 ease-in-out data-[open]:translate-x-0"
>
  <div class="flex flex-col h-full">
    <!-- Close Button -->
    <div class="flex justify-end p-4">
      <button id="nav-close" class="p-2" aria-label="Close menu">
        <i class="fas fa-times text-xl text-primary"></i>
      </button>
    </div>

    <!-- Mobile Navigation Links -->
    <ul class="flex flex-col items-end px-8 py-2 space-y-4">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href} class="nav-season-link block text-primary hover:text-gray-900 transition-colors py-2">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<!-- Mobile Menu Backdrop -->
<div
  id="nav-backdrop"
  class="fixed inset-0 bg-black/50 z-40 opacity-0 pointer-events-none transition-opacity duration-300 data-[open]:opacity-100 data-[open]:pointer-events-auto"
>
</div>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  const hamburger = document.getElementById('hamburger-btn')!;
  const nav = document.getElementById('main-nav')!;
  const backdrop = document.getElementById('nav-backdrop')!;
  const closeBtn = document.getElementById('nav-close')!;

  function openNav() {
    nav.dataset.open = '';
    backdrop.dataset.open = '';
    hamburger.classList.add('hidden');
  }

  function closeNav() {
    delete nav.dataset.open;
    delete backdrop.dataset.open;
    nav.addEventListener(
      'transitionend',
      () => {
        hamburger.classList.remove('hidden');
      },
      { once: true }
    );
  }

  hamburger.addEventListener('click', openNav);
  closeBtn.addEventListener('click', closeNav);
  backdrop.addEventListener('click', closeNav);

  // Close mobile nav when clicking a season link
  document.querySelectorAll('.nav-season-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 1024) closeNav();
    });
  });

  // Existing nav toggle logic
  document.querySelectorAll('.nav-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const group = btn.closest('.nav-group')!;
      const dropdown = group.querySelector('.nav-dropdown')!;
      const chevron = btn.querySelector('.fa-chevron-down')!;
      const isOpen = dropdown.hasAttribute('data-open');

      // Close all other dropdowns
      document.querySelectorAll('.nav-group').forEach((g) => {
        if (g !== group) {
          g.querySelector('.nav-dropdown')!.removeAttribute('data-open');
          g.querySelector('.fa-chevron-down')!.classList.remove('rotate-180');
          g.querySelector('.nav-toggle')!.removeAttribute('data-open');
        }
      });

      if (isOpen) {
        dropdown.removeAttribute('data-open');
        chevron.classList.remove('rotate-180');
        btn.removeAttribute('data-open');
      } else {
        dropdown.setAttribute('data-open', '');
        chevron.classList.add('rotate-180');
        btn.setAttribute('data-open', '');
      }
    });
  });
</script>
