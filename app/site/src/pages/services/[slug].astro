---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { getServiceBySlug } from '@/data/services';

const { slug } = Astro.params;
const service = slug ? getServiceBySlug(slug) : undefined;

if (!service) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${service.title} | KAMI & CO`} description={service.fullDescription}>
  <!-- Hero Section -->
  <section class="min-h-[60vh] flex items-center justify-center relative pt-16 px-6">
    <div class="max-w-2xl flex flex-col gap-6">
      <a href="/#services" class="fade-in-up flex items-center gap-2 text-sm text-white/80 group">
        <i class="fa fa-arrow-left text-xs group-hover:-translate-x-1 duration-500"></i>
        <span>Back to Services</span>
      </a>
      <h1 class="fade-in-up text-5xl lg:text-7xl font-black uppercase text-white">
        {service.title}
      </h1>
      <p class="fade-in-up max-w-2xl text-white/80 lg:text-base">
        {service.fullDescription}
      </p>
    </div>
    <section id="pricing" class="px-6">
      <div class="fade-in-right flex-1 z-2 mx-auto">
        <div
          class="lg:w-3xl mx-auto lg:p-16 p-8 flex flex-col gap-6 border-4 border-[#333] bg-gradient-to-br from-primary-dark/80 via-primary-dark/50 to-primary-dark/40
           relative group duration-500"
        >
          <!-- Shimmer background layer -->
          <div
            class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.15)_50%,transparent_75%)] bg-[length:250%_250%] bg-no-repeat bg-[position:130%_0] transition-[background-position] duration-[1500ms] group-hover:bg-[position:-100%_0] pointer-events-none"
          >
          </div>
          <div class="flex items-baseline gap-2">
            <p class="lg:text-8xl text-5xl font-extrabold text-white">{service.pricing.price}</p>
            {service.pricing.label && <span class="text-xl font-medium text-white">{service.pricing.label}</span>}
          </div>

          <div class="flex flex-col gap-2">
            <p class="text-2xl font-semibold">{service.title}</p>
            <p class="text-sm text-white leading-relaxed">
              {service.pricing.description}
            </p>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- Pricing Section -->

  <!-- Features Section -->
  <section class="py-16 px-6">
    <div class="container flex flex-col gap-8">
      <div class="flex flex-col gap-2">
        <h2 class="fade-in-up text-2xl lg:text-4xl font-bold text-white">What's Included</h2>
        <p class="fade-in-up text-white/80 max-w-xl">Everything you get when you choose this service.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          service.features.map((group) => (
            <div class={`fade-in-up flex flex-col gap-3`}>
              <h3 class="text-lg font-bold text-white">{group.category}</h3>
              <div class="flex flex-col gap-2">
                {group.items.map((item) => (
                  <div class="overflow-hidden font-bold flex items-center gap-2 p-3 border-2 border-[#333] bg-gray-50 hover:translate-y-1 hover:translate-x-1 duration-300 group relative">
                    <div class="w-full h-[2px] bg-[#c0fff4] absolute bottom-0 right-0 group-hover:h-full group-hover:w-full duration-300 z-0" />
                    <i class="text-[#40E0D0] group-hover:text-white duration-300 lg:text-sm text-xs fas fa-check z-1" />
                    <p class="text-white lg:text-sm text-xs z-1">{item}</p>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Add-Ons Section -->
  {
    service.addOns && service.addOns.length > 0 && (
      <section class="py-16 px-6">
        <div class="container flex flex-col gap-8">
          <div class="flex flex-col gap-2">
            <h2 class="fade-in-up text-2xl lg:text-4xl font-bold text-white">Add-Ons</h2>
            <p class="fade-in-up text-white/80 max-w-xl">Optional extras you can add to enhance this service.</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {service.addOns.map((group) => (
              <div class={`fade-in-up flex flex-col gap-3`}>
                <h3 class="text-lg font-bold text-white">{group.category}</h3>
                <div class="flex flex-col gap-2">
                  {group.items.map((item) => (
                    <div class="overflow-hidden font-bold flex items-center gap-2 p-3 border-2 border-[#333] bg-gray-50 hover:translate-y-1 hover:translate-x-1 duration-300 group relative">
                      <div class="w-full h-[2px] bg-[#c0fff4] absolute bottom-0 right-0 group-hover:h-full group-hover:w-full duration-300 z-0" />
                      <i class="text-[#40E0D0] group-hover:text-white duration-300 lg:text-sm text-xs fas fa-plus z-1" />
                      <p class="text-white lg:text-sm text-xs z-1">{item}</p>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA Section -->
  <section class="py-24 px-6 relative">
    <div
      class="container lg:p-16 p-4 pb-16 flex lg:flex-row flex-col items-center text-center gap-6 bg-[#141414] relative"
    >
      <img src="/images/cta.svg" alt="cta" class="w-auto lg:h-100 h-80 fade-in-left" />
      <div class="flex flex-col gap-6">
        <h2 class="fade-in-up text-3xl lg:text-4xl font-bold text-white">
          Still unsure? Let's figure it out together.
        </h2>
        <p class="fade-in-up text-white/80 max-w-xl lg:text-base text-sm">
          Every project is different. If you're not sure which service fits, what to include, or how things work — reach
          out. A quick conversation can help us understand what you need and plan the right approach.
        </p>
        <div class="fade-in-up">
          <Button href="/#contact" class="shadow-none hover:translate-none group gap-2">
            Get in Touch
            <i class="fa fa-arrow-up rotate-45 group-hover:rotate-90 duration-300"></i>
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .custom-shape-divider-bottom-1769328727 {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .custom-shape-divider-bottom-1769328727 svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 113px;
  }

  .custom-shape-divider-bottom-1769328727 .shape-fill {
    fill: #ffffff;
  }
</style>
