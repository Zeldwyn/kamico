---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { getServiceBySlug } from '@/data/services';
import First from '@/components/serviceSections/First.astro';
import Default from '@/components/serviceSections/Default.astro';
const { slug } = Astro.params;
const service = slug ? getServiceBySlug(slug) : undefined;

if (!service) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${service.title} | KAMI & CO`} description={service.fullDescription}>
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/10 pointer-events-none">
  </div>

  <!-- Hero Section -->
  <section
    class="min-h-[60vh] lg:max-w-[80%] mx-auto flex lg:flex-row flex-col lg:gap-0 gap-6 items-center justify-center relative pt-16 px-6"
  >
    <div class="lg:max-w-2xl flex flex-col gap-6 fade-in-left">
      <a href="/#services" class="flex items-center gap-2 text-sm text-white/80 group">
        <i class="fa fa-arrow-left text-xs group-hover:-translate-x-1 duration-500 gradient-text"></i>
        <span class="gradient-text duration-500">Back to Services</span>
      </a>
      <h1 class="text-5xl lg:text-7xl font-black uppercase text-white">
        {service.title}
      </h1>
      <p class="max-w-2xl text-white/80 lg:text-base">
        {service.fullDescription}
      </p>
    </div>

    <div class="fade-in-right flex-1 z-2 mx-auto">
      <div
        class="lg:w-3xl w-full mx-auto lg:p-16 p-8 flex flex-col gap-6 border-2 border-[#333] bg-gradient-to-br from-primary-dark/80 via-primary-dark/50 to-primary-dark/40
           relative group duration-500"
      >
        <!-- Shimmer background layer -->
        <div
          class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.15)_50%,transparent_75%)] bg-[length:250%_250%] bg-no-repeat bg-[position:130%_0] transition-[background-position] duration-[1500ms] group-hover:bg-[position:-100%_0] pointer-events-none"
        >
        </div>
        <div class="flex items-baseline gap-2">
          <p class="lg:text-8xl text-5xl font-extrabold text-white">{service.pricing.price}</p>
          {service.pricing.label && <span class="text-xl font-medium text-white">{service.pricing.label}</span>}
        </div>

        <div class="flex flex-col gap-2">
          <p class="text-2xl font-semibold">{service.title}</p>
          <p class="text-sm text-white leading-relaxed">
            {service.pricing.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->

  <!-- Features Section -->
  <section class="py-16 px-6">
    <div class="lg:w-[80%] mx-auto w-full flex flex-col gap-8">
      <div class="flex flex-col gap-2">
        <h2 class="fade-in-up text-2xl lg:text-4xl font-bold text-white">What's Included</h2>
        <p class="fade-in-up text-white/80 max-w-xl">Everything you get when you choose this service.</p>
      </div>
      <div class="flex flex-col gap-6">
        {
          (() => {
            const features = service.features;

            const firstGroups = features.slice(0, 2); // first 2
            const secondGroups = features.slice(2, 5); // next 3
            const restGroups = features.slice(5); // everything else

            return (
              <>
                {firstGroups.length > 0 && <First groups={firstGroups} />}

                {secondGroups.length > 0 && <Default groups={secondGroups} />}

                {restGroups.length > 0 && <Default groups={restGroups} />}
              </>
            );
          })()
        }
      </div>
    </div>
  </section>

  <!-- Add-Ons Section -->
  {
    service.addOns && service.addOns.length > 0 && (
      <section class="py-16 px-6">
        <div class="lg:w-[80%] mx-auto w-full flex flex-col gap-8">
          <div class="flex flex-col gap-2">
            <h2 class="fade-in-up text-2xl lg:text-4xl font-bold text-white">Add-Ons</h2>
            <p class="fade-in-up text-white/80 max-w-xl">Optional extras you can add to enhance this service.</p>
          </div>
          <div class="flex flex-col gap-6">
            {(() => {
              const features = service.addOns;

              const firstGroups = features.slice(0, 2); // first 2
              const secondGroups = features.slice(2, 5); // next 3
              const restGroups = features.slice(5); // everything else

              return (
                <>
                  {firstGroups.length > 0 && <Default groups={firstGroups} />}

                  {secondGroups.length > 0 && <Default groups={secondGroups} />}

                  {restGroups.length > 0 && <Default groups={restGroups} />}
                </>
              );
            })()}
            {/* {service.addOns.map((group) => (
              <div
                class={`fade-in-up flex flex-col gap-2 bg-gradient-to-br from-primary-dark/80 via-primary-dark/50 to-primary-dark/40 border-2 border-[#333] p-4`}
              >
                <h3 class="text-xl font-bold text-white">{group.category}</h3>
                <div class="flex flex-col gap-2 h-full">
                  {group.items.map((item) => (
                    <div class="overflow-hidden font-medium flex items-start gap-2 hover:translate-x-1 duration-300 group relative">
                      <div class="w-full h-[2px] bg-[#c0fff] absolute bottom-0 right-0 group-hover:h-full group-hover:w-full duration-300 z-0" />
                      <i class="text-primary-light mt-1 group-hover:text-white duration-300 lg:text-sm text-xs fas fa-check z-1" />
                      <p class="lg:text-sm text-xs z-1">{item}</p>
                    </div>
                  ))}
                </div>
              </div>
            ))} */}
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA Section -->
  <section class="lg:py-24 py-8 px-6 relative fade-in-up">
    <div
      class="max-w-7xl mx-auto lg:p-16 p-4 flex justify-center items-center text-center backdrop-blur-xs relative
              bg-[url('/images/service.webp')] bg-cover bg-center rounded-sm shadow-[0_0_4px_1px_#06b6d4] overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-background/80 to-background/70 pointer-events-none backdrop-blur-xs"
      >
      </div>
      <div class="flex flex-col items-center justify-center gap-4 rounded-sm z-2">
        <h2 class="text-3xl lg:text-4xl font-bold text-white">Still unsure? Let's figure it out together.</h2>
        <p class="text-white/80 max-w-xl lg:text-base text-xs">
          Every project is different. If you're not sure which service fits, what to include, or how things work — reach
          out. A quick conversation can help us understand what you need and plan the right approach.
        </p>

        <Button href="/#contact" text="Get Started" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .custom-shape-divider-bottom-1769328727 {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .custom-shape-divider-bottom-1769328727 svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 113px;
  }

  .custom-shape-divider-bottom-1769328727 .shape-fill {
    fill: #ffffff;
  }
</style>
