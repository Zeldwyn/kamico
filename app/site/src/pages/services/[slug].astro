---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import BookingModal from '@/components/ui/BookingModal.astro';
import { getServiceBySlug } from '@/data/services';

const SITE_URL = 'https://kamico.vercel.app';

const { slug } = Astro.params;
const service = slug ? getServiceBySlug(slug) : undefined;

if (!service) {
  return Astro.redirect('/404');
}

// Join items into a natural sentence: "A, B, C, and D."
function toSentence(items: string[]): string {
  if (items.length === 0) return '';
  if (items.length === 1) return items[0] + '.';
  const last = items[items.length - 1];
  const rest = items.slice(0, -1);
  return rest.join(', ') + ', and ' + last + '.';
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.title,
  description: service.fullDescription,
  url: `${SITE_URL}/services/${service.slug}`,
  provider: { '@type': 'Organization', name: 'Kami & Co', url: SITE_URL },
  areaServed: { '@type': 'Country', name: 'Philippines' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_URL}/#services` },
    { '@type': 'ListItem', position: 3, name: service.title, item: `${SITE_URL}/services/${service.slug}` },
  ],
};
---

<BaseLayout title={`${service.title} | KAMI & CO`} description={service.fullDescription}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/10 pointer-events-none"></div>

  <!-- Hero -->
  <section class="lg:max-w-[70%] mx-auto text-center px-6 pt-36 pb-20 fade-in-up">
    <a href="/#services" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/80 group transition-colors mb-8">
      <i class="fa fa-arrow-left text-xs group-hover:-translate-x-1 duration-300"></i>
      Back to Services
    </a>
    <h1 class="text-4xl lg:text-6xl font-black uppercase text-white leading-none mb-6">{service.title}</h1>
    <p class="text-white/60 text-base max-w-6xl leading-relaxed mx-auto">{service.fullDescription} Everything here is a starting point — if you have something specific in mind, we can always adjust it over a quick chat or meeting.</p>
  </section>

  <div class="lg:max-w-[70%] mx-auto px-6">
    <div class="border-t border-white/10"></div>
  </div>

  <!-- Overview — features as readable paragraphs -->
  <section class="lg:max-w-[70%] mx-auto px-6 py-20 flex flex-col gap-12 fade-in-up">
    {service.features.map((group) => (
      <div class="flex lg:flex-row flex-col lg:gap-16 gap-3">
        <p class="lg:w-48 shrink-0 text-xs font-black uppercase tracking-widest bg-gradient-to-r from-primary via-primary-light to-secondary/60 bg-clip-text text-transparent pt-1">
          {group.category}
        </p>
        <p class="text-white/70 text-base leading-relaxed flex-1">
          {toSentence(group.items)}
        </p>
      </div>
    ))}
  </section>

  <!-- Booking Showcase -->
  <div class="lg:max-w-[70%] mx-auto px-6">
    <div class="border-t border-white/10"></div>
  </div>
  <section class="lg:max-w-[70%] mx-auto px-6 py-16 fade-in-up">
    <div class="relative overflow-hidden bg-black/40 border-2 border-background/10 p-8 flex lg:flex-row flex-col lg:items-center justify-between gap-6 group">
      <div class="absolute inset-0 bg-[linear-gradient(90deg,transparent_25%,rgba(255,255,255,0.15)_50%,transparent_75%)] bg-[length:250%_250%] bg-no-repeat bg-[position:130%_0] transition-[background-position] duration-[1500ms] group-hover:bg-[position:-100%_0] pointer-events-none"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-primary/10 via-transparent to-secondary/10 pointer-events-none"></div>
      <div class="flex flex-col gap-2 z-10">
        <p class="text-xs font-black uppercase bg-gradient-to-r from-primary via-primary-light to-secondary/40 bg-clip-text text-transparent">Add-on Feature</p>
        <h3 class="text-xl font-bold text-white">Google Booking Integration</h3>
        <p class="text-white/50 text-sm max-w-lg">Let clients schedule appointments directly from your website. See a live sample before adding it to your project.</p>
      </div>
      <button data-open-modal="booking-modal-slug" class="z-10 shrink-0 inline-flex items-center gap-2 font-bold text-sm cursor-pointer group/btn">
        View Sample
        <i class="fa fa-arrow-up rotate-45 group-hover/btn:rotate-90 duration-300"></i>
      </button>
    </div>
  </section>

  <BookingModal
    modalId="booking-modal-slug"
    embedUrl="https://calendar.app.google/gKnEpum6PMJXJaTu6"
    embedTitle="Schedule an Appointment"
    embedHeight="650px"
    mode="light"
  />

  <!-- CTA -->
  <section class="lg:py-24 py-8 px-6 fade-in-up">
    <div class="max-w-7xl mx-auto lg:p-16 p-4 flex justify-center items-center text-center relative bg-[url('/images/service.webp')] bg-cover bg-center rounded-sm shadow-[0_0_4px_1px_#06b6d4] overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-background/80 to-background/70 pointer-events-none backdrop-blur-xs"></div>
      <div class="flex flex-col items-center justify-center gap-4 z-2">
        <h2 class="text-3xl lg:text-4xl font-bold text-white">Still unsure? Let's figure it out together.</h2>
        <p class="text-white/80 max-w-xl lg:text-base text-xs">
          Every project is different. If you're not sure which service fits, what to include, or how things work — reach out. A quick conversation can help us plan the right approach.
        </p>
        <Button href="/#contact" text="Get Started" />
      </div>
    </div>
  </section>
</BaseLayout>
