---
// First.astro

interface Props {
  groups: FeatureGroup[];
}

const { groups } = Astro.props as Props;
---

<div class="fade-in-up flex lg:flex-row flex-col gap-6">
  <!-- Section image -->
  <div class="w-full h-full relative">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/20 to-black/60 pointer-events-none"></div>
    <img src="/images/services/first.webp" alt="Service illustration" class="w-full h-full object-cover" />
  </div>

  <div class="flex flex-col justify-between gap-6 w-full">
    {groups.map((group: FeatureGroup) => (
      <div
        class="fade-in-up group relative w-full h-full flex flex-col items-start justify-center gap-2 bg-gradient-to-br from-primary-dark/80 via-primary-dark/50 to-primary-dark/40 border-2 border-[#333] p-6"
      >
        <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.15)_50%,transparent_75%)] bg-[length:250%_250%] bg-no-repeat bg-[position:130%_0] transition-[background-position] duration-[1500ms] group-hover:bg-[position:-100%_0] pointer-events-none"></div>
        <h3 class="lg:text-2xl text-xl font-bold text-white">{group.category}</h3>
        <div class="mt-2 space-y-2">
          {group.items.map((item: string) => (
            <p class="text-white/90 flex items-start   gap-2 lg:text-base text-sm duration-500 hover:translate-x-2">
              <i class="fas fa-star text-primary-light mt-0.5" /> {item}
            </p>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>
