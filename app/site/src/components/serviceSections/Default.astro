---
// Default.astro

interface Props {
  groups: FeatureGroup[];
}

const { groups } = Astro.props as Props;

const count = groups.length;

const gridCols =
  count === 1
    ? 'grid-cols-1'
    : count === 2
    ? 'grid-cols-1 md:grid-cols-2'
    : 'grid-cols-1 md:grid-cols-3';
---

<div class={`fade-in-up grid gap-6 ${gridCols}`}>
  {groups.map((group: FeatureGroup) => (
    <div class="relative group w-full h-full flex flex-col gap-2 bg-gradient-to-br from-primary-dark/80 via-primary-dark/50 to-primary-dark/40 border-2 border-[#333] p-6">
      <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.15)_50%,transparent_75%)] bg-[length:250%_250%] bg-no-repeat bg-[position:130%_0] transition-[background-position] duration-[1500ms] group-hover:bg-[position:-100%_0] pointer-events-none" />
      <h3 class="text-2xl font-bold text-white">{group.category}</h3>

      <div class="mt-2 space-y-2">
        {group.items.map((item: string) => (
          <p class="text-white/90 flex items-center gap-2 duration-500 hover:translate-x-2">
            <i class="fas fa-star text-primary-light" />
            {item}
          </p>
        ))}
      </div>
    </div>
  ))}
</div>
