---
/**
 * Color System Showcase Component
 * Demonstrates all available colors and common UI patterns
 * Use this as a reference or delete after reviewing
 */
---

<div class="container py-12">
  <h1 class="text-4xl font-bold text-foreground mb-8">Color System Showcase</h1>

  <!-- Brand Colors -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-foreground mb-4">Brand Colors</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-primary text-white p-6 rounded-lg">
        <p class="font-bold">Primary</p>
        <p class="text-sm opacity-90">bg-primary</p>
      </div>
      <div class="bg-primary-hover text-white p-6 rounded-lg">
        <p class="font-bold">Primary Hover</p>
        <p class="text-sm opacity-90">bg-primary-hover</p>
      </div>
      <div class="bg-primary-light text-foreground p-6 rounded-lg">
        <p class="font-bold">Primary Light</p>
        <p class="text-sm opacity-90">bg-primary-light</p>
      </div>
      <div class="bg-secondary text-white p-6 rounded-lg">
        <p class="font-bold">Secondary</p>
        <p class="text-sm opacity-90">bg-secondary</p>
      </div>
      <div class="bg-accent text-foreground p-6 rounded-lg">
        <p class="font-bold">Accent</p>
        <p class="text-sm opacity-90">bg-accent</p>
      </div>
    </div>
  </section>

  <!-- State Colors -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-foreground mb-4">State Colors</h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-success text-white p-6 rounded-lg">
        <p class="font-bold">Success</p>
        <p class="text-sm opacity-90">bg-success</p>
      </div>
      <div class="bg-error text-white p-6 rounded-lg">
        <p class="font-bold">Error</p>
        <p class="text-sm opacity-90">bg-error</p>
      </div>
      <div class="bg-warning text-white p-6 rounded-lg">
        <p class="font-bold">Warning</p>
        <p class="text-sm opacity-90">bg-warning</p>
      </div>
      <div class="bg-info text-white p-6 rounded-lg">
        <p class="font-bold">Info</p>
        <p class="text-sm opacity-90">bg-info</p>
      </div>
    </div>
  </section>

  <!-- Buttons -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-foreground mb-4">Button Variants</h2>
    <div class="flex flex-wrap gap-4">
      <button class="bg-primary hover:bg-primary-hover text-white px-6 py-3 rounded-lg font-semibold transition-colors">
        Primary Button
      </button>
      <button class="bg-secondary hover:bg-secondary-hover text-white px-6 py-3 rounded-lg font-semibold transition-colors">
        Secondary Button
      </button>
      <button class="border-2 border-primary text-primary hover:bg-primary hover:text-white px-6 py-3 rounded-lg font-semibold transition-all">
        Outline Button
      </button>
      <button class="text-primary hover:bg-primary/10 px-6 py-3 rounded-lg font-semibold transition-colors">
        Ghost Button
      </button>
      <button class="bg-accent hover:bg-accent-hover text-foreground px-6 py-3 rounded-lg font-semibold transition-colors">
        Accent Button
      </button>
    </div>
  </section>

  <!-- Cards -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-foreground mb-4">Card Variants</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-surface border border-border rounded-lg p-6 shadow-sm">
        <h3 class="text-xl font-bold text-foreground mb-2">Default Card</h3>
        <p class="text-muted mb-4">This is a standard card with surface background and border.</p>
        <button class="bg-primary text-white px-4 py-2 rounded hover:bg-primary-hover transition-colors">
          Action
        </button>
      </div>
      <div class="bg-surface-elevated border border-border-subtle rounded-lg p-6 shadow-md">
        <h3 class="text-xl font-bold text-foreground mb-2">Elevated Card</h3>
        <p class="text-muted mb-4">This card has an elevated background and more prominent shadow.</p>
        <button class="bg-secondary text-white px-4 py-2 rounded hover:bg-secondary-hover transition-colors">
          Action
        </button>
      </div>
    </div>
  </section>

  <!-- Alerts -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-foreground mb-4">Alert Messages</h2>
    <div class="space-y-4">
      <div class="bg-success/10 border-l-4 border-success p-4 rounded">
        <p class="text-success font-semibold mb-1">Success!</p>
        <p class="text-foreground/80">Your changes have been saved successfully.</p>
      </div>
      <div class="bg-error/10 border-l-4 border-error p-4 rounded">
        <p class="text-error font-semibold mb-1">Error!</p>
        <p class="text-foreground/80">An error occurred while processing your request.</p>
      </div>
      <div class="bg-warning/10 border-l-4 border-warning p-4 rounded">
        <p class="text-warning font-semibold mb-1">Warning!</p>
        <p class="text-foreground/80">Please review this information before continuing.</p>
      </div>
      <div class="bg-info/10 border-l-4 border-info p-4 rounded">
        <p class="text-info font-semibold mb-1">Information</p>
        <p class="text-foreground/80">Here's some helpful information about this feature.</p>
      </div>
    </div>
  </section>

  <!-- Forms -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-foreground mb-4">Form Elements</h2>
    <div class="space-y-4 max-w-md">
      <div>
        <label class="block text-foreground font-semibold mb-2">Standard Input</label>
        <input
          type="text"
          class="w-full border border-border rounded-lg px-4 py-2 focus:ring-2 focus:ring-focus focus:border-focus outline-none transition-all"
          placeholder="Enter text..."
        />
      </div>
      <div>
        <label class="block text-error font-semibold mb-2">Error Input</label>
        <input
          type="text"
          class="w-full border-2 border-error rounded-lg px-4 py-2 focus:ring-2 focus:ring-error outline-none"
          placeholder="Invalid input"
        />
        <p class="text-error text-sm mt-1">This field is required</p>
      </div>
      <div>
        <label class="block text-success font-semibold mb-2">Success Input</label>
        <input
          type="text"
          class="w-full border-2 border-success rounded-lg px-4 py-2 focus:ring-2 focus:ring-success outline-none"
          value="Valid input"
        />
        <p class="text-success text-sm mt-1">Looks good!</p>
      </div>
    </div>
  </section>

  <!-- Text Colors -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-foreground mb-4">Text Colors</h2>
    <div class="space-y-2">
      <p class="text-foreground text-lg">Foreground text (primary text color)</p>
      <p class="text-muted text-lg">Muted text (secondary text color)</p>
      <p class="text-subtle text-lg">Subtle text (tertiary text color)</p>
      <p class="text-primary text-lg">Primary brand text</p>
      <p class="text-secondary text-lg">Secondary brand text</p>
    </div>
  </section>

  <!-- Opacity Examples -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-foreground mb-4">Opacity Modifiers</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      <div class="bg-primary text-white p-4 rounded text-center">
        <p class="font-bold">100%</p>
      </div>
      <div class="bg-primary/80 text-white p-4 rounded text-center">
        <p class="font-bold">80%</p>
      </div>
      <div class="bg-primary/60 text-white p-4 rounded text-center">
        <p class="font-bold">60%</p>
      </div>
      <div class="bg-primary/40 text-foreground p-4 rounded text-center">
        <p class="font-bold">40%</p>
      </div>
      <div class="bg-primary/20 text-foreground p-4 rounded text-center">
        <p class="font-bold">20%</p>
      </div>
    </div>
  </section>
</div>
