---
interface Props {
  type?: 'text' | 'email' | 'tel' | 'password';
  name: string;
  label: string;
  required?: boolean;
  class?: string;
}

const { type = 'text', name, label, required = false, class: className = '' } = Astro.props;

// Generate a random autocomplete value to prevent browser autocomplete
const randomAutocomplete = `new-${name}-${Math.random().toString(36).substring(7)}`;
---

<div class={`relative lg:text-sm text-xs ${className}`}>
  <input
    type={type}
    name={name}
    required={required}
    placeholder=" "
    autocomplete={randomAutocomplete}
    class="peer w-full h-full rounded-lg border border-white/10 bg-black/40 py-3 px-3 outline-none z-1 active:bg-transparent"
  />

  <span
    class="absolute left-3 top-1/2 -translate-y-1/2 text-muted transition-all duration-300 pointer-events-none
          peer-focus:-top-2 peer-focus:translate-y-0 peer-focus:text-primary peer-focus:px-2 peer-valid:px-2 peer-valid:text-primary
          peer-valid:-top-2 peer-valid:translate-y-0 peer-focus:text-xs peer-valid:text-xs bg-black z-2"
  >
    {label}
  </span>
</div>
