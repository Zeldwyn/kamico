---
interface Props {
  name: string;
  label: string;
  rows?: number;
  required?: boolean;
  class?: string;
}

const { name, label, rows = 5, required = false, class: className = '' } = Astro.props;

// Generate a random autocomplete value to prevent browser autocomplete
const randomAutocomplete = `new-${name}-${Math.random().toString(36).substring(7)}`;
---

<div class={`relative lg:text-sm text-xs ${className}`}>
  <textarea
    name={name}
    rows={rows}
    required={required}
    placeholder=" "
    autocomplete={randomAutocomplete}
    class="peer w-full h-full rounded-lg border border-white/10 bg-black/40 py-2 px-3 outline-none resize-none z-1"
  ></textarea>

  <span
    class="absolute left-3 top-4 text-muted transition-all duration-300 pointer-events-none
          peer-focus:-top-2 peer-focus:text-primary peer-focus:px-2 peer-valid:px-2
          peer-valid:-top-2 peer-focus:text-xs peer-valid:text-xs bg-black z-2"
  >
    {label}
  </span>
</div>
