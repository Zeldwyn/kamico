---
interface Props {
  text?: string;
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  id?: string;
}

const { text = 'Get Started', href, class: className, type = 'button', disabled = false, id } = Astro.props;
const baseClasses = `inline-block bg-primary/20 border border-primary-light shadow-[0_0_8px_1px_#06b6d4] backdrop-blur-md text-white px-8 py-3
                      rounded-lg transition-all duration-500 tracking-wider uppercase lg:text-base text-xs group
                      disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 disabled:shadow-none relative`;
const buttonClasses = className ? `${baseClasses} ${className}` : baseClasses;
---

{
  href ? (
    <a href={href} class={buttonClasses}>
      <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.15)_50%,transparent_75%)] bg-[length:250%_250%] bg-no-repeat bg-[position:130%_0] transition-[background-position] duration-[1500ms] group-hover:bg-[position:-100%_0] pointer-events-none"></div>
      {text}
    </a>
  ) : (
    <button type={type} disabled={disabled} id={id} class={buttonClasses}>
      <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.15)_50%,transparent_75%)] bg-[length:250%_250%] bg-no-repeat bg-[position:130%_0] transition-[background-position] duration-[1500ms] group-hover:bg-[position:-100%_0] pointer-events-none"></div>
      {text}
    </button>
  )
}
