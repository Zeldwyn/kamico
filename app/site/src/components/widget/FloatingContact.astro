---
const floatingButtons = [
  {
    id: 'facebook',
    href: 'https://www.facebook.com/KamiAndCo',
    label: 'Facebook',
    icon: 'fa-brands fa-facebook-f',
  },
  {
    id: 'whatsapp',
    href: 'https://wa.me/639193625924',
    label: 'WhatsApp',
    icon: 'fa-brands fa-whatsapp',
  },
  {
    id: 'telegram',
    href: 'https://t.me/zeldwyn',
    label: 'Telegram',
    icon: 'fa-brands fa-telegram',
  },
  {
    id: 'mail',
    href: 'mailto:contact.kamico@gmail.com',
    label: 'Email',
    icon: 'fa-solid fa-envelope',
  },
];
---

<div class="fixed bottom-4 left-4 md:bottom-8 md:left-8 z-[9999] hidden lg:flex flex-col gap-3">
  {
    floatingButtons.map((btn) => (
      <div class="relative group">
        {/* Tooltip */}
        <div
          class="absolute left-full ml-3 top-1/2 -translate-y-1/2
                 px-3 py-1 rounded-md text-xs font-medium whitespace-nowrap
                 text-white opacity-0 scale-95 pointer-events-none
                 transition-all duration-200 group-hover:opacity-100 group-hover:scale-100"
        >
          {btn.label}
        </div>

        <a
          href={btn.href}
          id={`floating-btn-${btn.id}`}
          aria-label={btn.label}
          target="_blank"
          rel="noopener noreferrer"
          class="pointer-events-none opacity-0
                 w-8 h-8 md:w-10 md:h-10 rounded-full
                 bg-gradient-to-br from-primary-dark via-primary to-primary-light
                 border border-white/40
                 shadow-[0_0_0_4px_rgba(255,255,255,0.1)]
                 flex items-center justify-center"
        >
          <i class={btn.icon} />
        </a>
      </div>
    ))
  }
</div>
