---
/**
 * ScrollToTop.astro
 * Scroll to top button component that appears when user scrolls down
 */
---

<button
  id="scroll-to-top"
  class="opacity-0 pointer-events-none button text-xs"
  aria-label="Scroll to top"
>
  <svg
    class="svgIcon"
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M12 19V5M12 5L5 12M12 5L19 12"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</button>

<style>
  #scroll-to-top {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    z-index: 9999;
  }

  @media (min-width: 768px) {
    #scroll-to-top {
      bottom: 2rem;
      right: 2rem;
    }
  }

  .button {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #2a3e32;
    border: 2px solid rgba(255, 255, 255, 0.4);
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0px 0px 0px 4px rgba(255, 255, 255, 0.1);
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.5s ease;
    overflow: hidden;
    position: relative;
  }

  @media (min-width: 768px) {
    .button {
      width: 50px;
      height: 50px;
    }
  }

  .svgIcon {
    width: 16px;
    height: 16px;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .svgIcon {
      width: 18px;
      height: 18px;
    }
  }

  .svgIcon path {
    stroke: white;
  }

  .button:hover {
    transform: translateY(-0.5rem);
  }
</style>
