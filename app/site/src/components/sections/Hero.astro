---

<!-- Hero Section -->
<section id="hero" class="min-h-screen flex items-center justify-center bg-background text-foreground relative overflow-hidden">
  <!-- Cyan accent gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/10 pointer-events-none"></div>

  <div class="container mx-auto px-4 text-center relative z-10">
    <h1 class="text-4xl md:text-6xl font-bold mb-6 fade-in-up bg-gradient-to-r from-primary via-primary-light to-secondary bg-clip-text text-transparent">
      Welcome to Your Site
    </h1>
    <p class="text-xl max-w-2xl mx-auto mb-8 text-muted fade-in-up stagger-1">
      A brief tagline or description of what you offer goes here.
    </p>
    <a
      href="#contact"
      class="inline-block bg-primary text-black px-8 py-3 rounded-lg font-semibold hover:bg-primary-hover hover:scale-105 transition-all duration-300 fade-in-up stagger-2 shadow-lg shadow-primary/50"
    >
      Get Started
    </a>
  </div>
</section>
